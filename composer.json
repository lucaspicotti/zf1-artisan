{
    "name": "lucaspicotti/zf1-artisan",
    "description": "Ferramenta CLI estilo Artisan para o Zend1",
    "type": "library",
    "bin": [
        "artisan"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "authors": [
        {
            "name": "lucaspicotti"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "symfony/console": "^5.4",
        "symfony/filesystem": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.10"
    }
}
