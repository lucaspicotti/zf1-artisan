#!/usr/bin/env php
<?php

use App\Console\Commands\MakeControllerCommand;
use App\Console\Commands\MakeModelCommand;
use App\Console\Commands\MakeCronCommand;
use Symfony\Component\Console\Application;
use Symfony\Component\Dotenv\Dotenv;
use App\Console\Commands\TemplateCommand;

// Carrega o autoload do Composer
// TODO: futuramente deverá incluir autoload do zend
require __DIR__ . '/vendor/autoload.php';

$dotenv = new Dotenv();
if (file_exists(__DIR__ . '/.env')) {
    $dotenv->load(__DIR__ . '/.env');
}

// Inicializa a aplicação de Console do Symfony
$application = new Application($_ENV['APPLICATION_NAME'] ?? 'Artisan ZF1', '1.0.0');

$application->add(new TemplateCommand());
$application->add(new MakeControllerCommand());
$application->add(new MakeModelCommand());
$application->add(new MakeCronCommand());

// Executa a aplicação
$application->run();
